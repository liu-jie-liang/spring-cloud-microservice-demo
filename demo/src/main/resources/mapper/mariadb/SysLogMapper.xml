<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.mariadb.SysLogMapper">
    <insert id="insert" parameterType="com.example.demo.bean.SysLog">
        insert into syslog
        (username, operation, time, method, params, ip, create_time)
        values
        (#{username}, #{operation}, #{time}, #{method}, #{params}, #{ip}, #{createTime})
    </insert>

    <select id="select" resultType="com.example.demo.bean.SysLog">
        select * from syslog where id = #{id}
    </select>
</mapper>