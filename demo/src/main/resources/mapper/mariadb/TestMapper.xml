<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.mariadb.TestMapper">
    <insert id="insert" parameterType="com.example.demo.bean.Test">
        insert into test
        (timestamp, date)
        values
        (#{timestamp}, #{date})
    </insert>

    <select id="search" resultType="com.example.demo.bean.Test">
        select * from test where id = #{id}
    </select>
</mapper>